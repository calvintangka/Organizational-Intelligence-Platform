generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum KnowledgeLifecycleState {
  active
  candidate
  deprecated
}

enum KnowledgeCandidateLifecycle {
  proposed
  validated
  rejected
}

enum ValidationDecision {
  approved
  rejected
}

enum TicketRecordLifecycle {
  open
  in_review
  resolved
  rejected
  discarded
}

enum EmergingPatternLifecycle {
  monitoring
  suggested
  promoted
  dismissed
}

enum MigrationImportBatchStatus {
  pending
  validating
  ready
  importing
  partial
  conflict
  imported
  verifying
  verified
  failed
}

enum MigrationImportResourceType {
  knowledge
  knowledgeCandidates
  validationRecords
  memoryChangeRecords
  orgMetrics
  intelligenceLog
  emergingPatterns
  ticketRecords
  ticketSequence
}

enum MigrationImportResourceStatus {
  pending
  validating
  importing
  imported
  conflict
  failed
  verified
}

enum MigrationImportConflictType {
  same_id_different_content
  cross_organization_ownership_mismatch
  duplicate_candidate_validation
  duplicate_validation_memory_relationship
  ticket_id_collision
  lesson_id_content_conflict
  knowledge_version_id_conflict
  unresolved_historical_reference
  digest_mismatch
  malformed_source_record
}

enum MigrationImportConflictStatus {
  open
  resolved_source
  resolved_target
  resolved_manual
  ignored
}

model Organization {
  id          String   @id
  name        String
  industry    String
  description String
  settings    Json
  createdAt   DateTime @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  knowledgeItems      KnowledgeItem[]
  knowledgeCandidates KnowledgeCandidate[]
  validationRecords   ValidationRecord[]
  memoryChangeRecords MemoryChangeRecord[]
  ticketRecords       TicketRecord[]
  emergingPatterns    EmergingPattern[]
  intelligenceLogs    IntelligenceLog[]
  orgMetrics          OrgMetrics?
  ticketSequence      TicketSequence?
  migrationImportBatches    MigrationImportBatch[]
  migrationImportConflicts  MigrationImportConflict[]

  @@map("organizations")
}

model KnowledgeItem {
  id                       String                  @id
  organizationId           String
  title                    String
  category                 String
  canonicalProblemId       String?
  canonicalProblemTitle    String?
  lifecycleState           KnowledgeLifecycleState @default(active)
  sourceTicketId           String
  timesReused              Int                     @default(0)
  timesSeen                Int?
  successfulResolutions    Int?
  failedResolutions        Int?
  successRate              Float?
  trustScore               Int?
  autoResponseEligible     Boolean?
  humanReviewCount         Int?
  automaticResolutionCount Int?
  createdAt                DateTime                @db.Timestamptz(6)
  approvedAt               DateTime                @db.Timestamptz(6)
  lastUsedAt               DateTime?               @db.Timestamptz(6)
  lastValidatedAt          DateTime?               @db.Timestamptz(6)
  lastUpdatedAt            DateTime?               @db.Timestamptz(6)
  lastValidated            DateTime?               @db.Timestamptz(6)
  // Optimistic concurrency control for canonical knowledge writes. Every
  // committed update must present the current revision and bumps it by one.
  revision                 Int                     @default(0)
  content                  Json

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, category])
  @@index([organizationId, canonicalProblemId])
  @@map("knowledge_items")
}

model KnowledgeCandidate {
  id                 String                      @id
  organizationId     String
  relatedKnowledgeId String?
  sourceTicketIds    Json
  proposedAction     String
  proposedContent    Json
  rationale          String
  status             KnowledgeCandidateLifecycle @default(proposed)
  createdAt          DateTime                    @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, relatedKnowledgeId])
  @@map("knowledge_candidates")
}

model ValidationRecord {
  id                 String             @id
  organizationId     String
  candidateId        String
  knowledgeItemId    String?
  knowledgeVersionId String?
  decision           ValidationDecision
  actor              String
  actorId            String?
  roleExercised      String
  rationale          String?
  timestamp          DateTime           @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Each knowledge candidate is validated exactly once in the current domain
  // workflow; this blocks duplicate validation submissions at the database.
  @@unique([organizationId, candidateId])
  @@index([organizationId])
  @@index([organizationId, knowledgeItemId])
  @@index([organizationId, timestamp])
  @@map("validation_records")
}

model MemoryChangeRecord {
  id                 String   @id
  organizationId     String
  knowledgeItemId    String
  candidateId        String
  validationRecordId String
  actorId            String?
  changeType         String
  beforeState        Json?
  afterState         Json
  timestamp          DateTime @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // One memory-change audit record per validation record: a retried commit can
  // never append a second before/after snapshot for the same validation.
  @@unique([organizationId, validationRecordId])
  @@index([organizationId])
  @@index([organizationId, knowledgeItemId])
  @@index([organizationId, timestamp])
  @@map("memory_change_records")
}

model TicketRecord {
  id                  String                @id @default(cuid())
  organizationId      String
  ticketId            String
  rawMessage          String
  subject             String?
  status              TicketRecordLifecycle @default(open)
  draftSource         String?
  classification      Json?
  memoryMatch         Json?
  resolution          Json
  reflection          Json
  validationRecordIds Json
  actorId             String?
  createdAt           DateTime              @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, ticketId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("ticket_records")
}

model EmergingPattern {
  id                        String                   @id
  organizationId            String
  title                     String
  summary                   String
  category                  String
  status                    EmergingPatternLifecycle @default(monitoring)
  tags                      Json
  keywords                  Json
  exampleTickets            Json
  timesSeen                 Int
  confidenceScore           Float
  suggestedCanonicalProblem Boolean
  firstSeenAt               DateTime                 @db.Timestamptz(6)
  lastSeenAt                DateTime                 @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, category])
  @@index([organizationId, lastSeenAt])
  @@map("emerging_patterns")
}

model OrgMetrics {
  organizationId             String   @id
  lifetimeTickets            Int
  knowledgeReused            Int
  autoResolutions            Int
  humanResolutions           Int
  totalResolutionTimeSec     Int
  resolutionsCount           Int
  memoryGrowthToday          Int
  memoryGrowthDate           String
  mergedTickets              Int?
  duplicatePreventions       Int?
  knowledgeVersions          Int?
  emergingPatternsDetected   Int?
  promotedPatterns           Int?
  aiCalls                    Int?
  aiSuccesses                Int?
  aiFailures                 Int?
  aiFallbacks                Int?
  aiAgreementSamples         Int?
  aiAgreementTotal           Int?
  humanAcceptedAISuggestions Int?
  lastUpdatedAt              DateTime @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_metrics")
}

model IntelligenceLog {
  id             String   @id
  organizationId String
  timestamp      DateTime @db.Timestamptz(6)
  event          String
  detail         String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, timestamp])
  @@map("intelligence_log")
}

model TicketSequence {
  organizationId String   @id
  counter        Int      @default(0)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("ticket_sequences")
}

model MigrationImportBatch {
  id                    String                   @id @default(cuid())
  organizationId        String
  format                String
  formatVersion         Int
  resourcePayloadDigest String
  metadataDigest        String?
  sourceOrganizationId  String
  sourcePersistenceMode String
  sourceSchemaVersion   String
  exportedAt            DateTime                 @db.Timestamptz(6)
  counts                Json
  resourceDigests       Json
  // Immutable, validated oip-localstorage-export-v1 package retained for a
  // later Batch 5.4 import attempt. This is not arbitrary browser storage.
  packagePayload         Json?
  status                MigrationImportBatchStatus @default(pending)
  attemptCount          Int                      @default(0)
  errorSummary          String?
  createdAt             DateTime                 @default(now()) @db.Timestamptz(6)
  startedAt             DateTime?                @db.Timestamptz(6)
  completedAt           DateTime?                @db.Timestamptz(6)
  verificationCompletedAt DateTime?              @db.Timestamptz(6)
  updatedAt             DateTime                 @updatedAt @db.Timestamptz(6)

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resources    MigrationImportResource[]
  conflicts    MigrationImportConflict[]

  @@unique([organizationId, resourcePayloadDigest])
  @@index([organizationId, status])
  @@index([resourcePayloadDigest])
  @@map("migration_import_batches")
}

model MigrationImportResource {
  id                    String                    @id @default(cuid())
  batchId               String
  resourceType          MigrationImportResourceType
  expectedCount         Int                       @default(0)
  importedCount         Int                       @default(0)
  skippedIdenticalCount  Int                       @default(0)
  conflictCount         Int                       @default(0)
  sourceDigest           String
  targetDigest           String?
  status                MigrationImportResourceStatus @default(pending)
  attemptCount          Int                       @default(0)
  errorSummary          String?
  createdAt             DateTime                  @default(now()) @db.Timestamptz(6)
  startedAt             DateTime?                 @db.Timestamptz(6)
  completedAt           DateTime?                 @db.Timestamptz(6)
  updatedAt             DateTime                  @updatedAt @db.Timestamptz(6)

  batch MigrationImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, resourceType])
  @@index([batchId, status])
  @@map("migration_import_resources")
}

model MigrationImportConflict {
  id             String                       @id @default(cuid())
  batchId        String
  organizationId String
  resourceType   MigrationImportResourceType
  fingerprint    String
  sourceRecordId String?
  conflictType   MigrationImportConflictType
  sourceDigest   String?
  targetDigest   String?
  sourceSnapshot Json?
  targetSnapshot Json?
  reason         String
  status         MigrationImportConflictStatus @default(open)
  detectedAt     DateTime                     @default(now()) @db.Timestamptz(6)
  resolvedAt     DateTime?                    @db.Timestamptz(6)
  createdAt      DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                     @updatedAt @db.Timestamptz(6)

  batch        MigrationImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([batchId, fingerprint])
  @@index([organizationId, status])
  @@index([batchId, status])
  @@map("migration_import_conflicts")
}
